{
  "productName": "Hort",
  "version": "0.2.5",
  "identifier": "de.s16e.hort",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5179",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "appimage"],
    "category": "DeveloperTool",
    "shortDescription": "Local secret and config store",
    "longDescription": "Hort desktop UI — browse, manage, and explore local secret and config vaults. Talks to the hort daemon over its Unix socket and mirrors every action back as the equivalent CLI command.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns"
    ]
  },
  "app": {
    "windows": [
      {
        "title": "",
        "width": 1100,
        "height": 720,
        "minWidth": 720,
        "minHeight": 420,
        "center": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
